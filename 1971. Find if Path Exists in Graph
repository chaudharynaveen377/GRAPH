class Solution {
    static int find(int x,int[]parent){
        if(x==parent[x]){
            return x;
        }
        return x=find(parent[x],parent);
    }
    static void union(int x ,int y,int size[],int parent[]){
int px=find(x,parent);
int py=find(y,parent);

if(px==py)return;

if(size[px]>size[py]){
    parent[py]=px;
    size[px]+=size[py];
}else{
      parent[px]=py;
    size[py]+=size[px];
}

    }
    public boolean validPath(int n, int[][] edges, int source, int destination) {
        
        int size[]=new int[n];
        int parent[]=new int[n];

        for(int i=0;i<n;i++){
            size[i]=1;
            parent[i]=i;
        }

        for(int i=0;i<edges.length;i++){
            int a=edges[i][0];
            int b=edges[i][1];

            union(a,b,size,parent);
        }

        return find(source,parent)==find(destination,parent);

    }
}
