class Solution {
    static int comp;
    static int find(int x, int[]parent){
        if(x==parent[x]){
            return x;
        }
        return parent[x]=find(parent[x],parent);
    }
    static boolean union(int x,int y , int[] size,int[] parent){
        int px = find(x, parent);
        int py = find(y,parent);

        if(px==py) return false;

        if(size[px] < size[py]){
            int temp = px;
            px= py;
            py=temp;
        }
        comp--;
        parent[py]=px;
        size[px]+=size[py];
        return true;

    }
    public int removeStones(int[][] stones) {
        int n =stones.length;
        comp=n;
        int ans =0;
        int[] parent = new int[n];
        for(int i =0 ;i<n;i++){
            parent[i]=i;
        }
        int []size = new int[n];
        Arrays.fill(size,1);
        for(int i =0 ; i< n ;i++){
            for(int j =i+1 ; j< n ;j++){
                if(stones[i][0]==stones[j][0] || stones[i][1]==stones[j][1])
                union(i,j,size,parent);
            }
        }
     
        return n-comp;
    }
}
