class Solution {
   
static int dfs(int src,int parent,ArrayList<ArrayList<Integer>> adj,List<Boolean> hasApple){
    int time=0;
    for(int child : adj.get(src)){
        if(child==parent)continue;
      int childcall=dfs(child,src,adj,hasApple);
      if(childcall>0 || hasApple.get(child)){
        time+=childcall+2;
      }
    }
    return time;
}
    public int minTime(int n, int[][] edges, List<Boolean> hasApple) {
        ArrayList<ArrayList<Integer>> adj=new ArrayList<>();
for(int i=0;i<=n;i++){
    adj.add(new ArrayList<>());
}
        for(int i=0;i<edges.length;i++){
            int u=edges[i][0];
            int v=edges[i][1];
adj.get(u).add(v);
adj.get(v).add(u);
        } 


        return dfs(0,-1,adj,hasApple);
    }

    
}
